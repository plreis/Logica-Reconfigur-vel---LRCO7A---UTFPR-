/*<simulation_settings>
<ftestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off atividade6 -c atividade6 --vector_source="/home/plreis/projetosfpga/atividade6/Waveform.vwf" --testbench_file="/home/plreis/projetosfpga/atividade6/simulation/qsim/Waveform.vwf.vht"</ftestbench_cmd>
<ttestbench_cmd>quartus_eda --gen_testbench --tool=modelsim_oem --format=vhdl --write_settings_files=off atividade6 -c atividade6 --vector_source="/home/plreis/projetosfpga/atividade6/Waveform.vwf" --testbench_file="/home/plreis/projetosfpga/atividade6/simulation/qsim/Waveform.vwf.vht"</ttestbench_cmd>
<fnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=on --flatten_buses=off --tool=modelsim_oem --format=vhdl --output_directory="/home/plreis/projetosfpga/atividade6/simulation/qsim/" atividade6 -c atividade6</fnetlist_cmd>
<tnetlist_cmd>quartus_eda --write_settings_files=off --simulation --functional=off --flatten_buses=off --timescale=1ps --tool=modelsim_oem --format=vhdl --output_directory="/home/plreis/projetosfpga/atividade6/simulation/qsim/" atividade6 -c atividade6</tnetlist_cmd>
<modelsim_script>onerror {exit -code 1}
vlib work
vcom -work work atividade6.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -L fiftyfivenm -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.atividade6_vhd_vec_tst
vcd file -direction atividade6.msim.vcd
vcd add -internal atividade6_vhd_vec_tst/*
vcd add -internal atividade6_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f
</modelsim_script>
<modelsim_script_timing>onerror {exit -code 1}
vlib work
vcom -work work atividade6.vho
vcom -work work Waveform.vwf.vht
vsim -novopt -c -t 1ps -sdfmax atividade6_vhd_vec_tst/i1=atividade6_vhd.sdo -L fiftyfivenm -L altera -L altera_mf -L 220model -L sgate -L altera_lnsim work.atividade6_vhd_vec_tst
vcd file -direction atividade6.msim.vcd
vcd add -internal atividade6_vhd_vec_tst/*
vcd add -internal atividade6_vhd_vec_tst/i1/*
proc simTimestamp {} {
    echo "Simulation time: $::now ps"
    if { [string equal running [runStatus]] } {
        after 2500 simTimestamp
    }
}
after 2500 simTimestamp
run -all
quit -f
</modelsim_script_timing>
<hdl_lang>vhdl</hdl_lang>
</simulation_settings>*/
